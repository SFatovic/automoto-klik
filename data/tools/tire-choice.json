      "label": "Što ti je najvažnije kod guma",
      "type": "checkbox",
      "required": true,
      "options": [
        "Sigurnost i prianjanje",
        "Dugotrajnost",
        "Niska buka",
        "Udobnost",
        "Ušteda goriva",
        "Povoljna cijena",
        "Sportske performanse"
      ]
    },
    {
      "id": "annualMileage",
      "label": "Koliko otprilike kilometara radiš godišnje",
      "type": "select",
      "required": false,
      "options": [
        "Manje od 10.000 km",
        "10.000 - 20.000 km",
        "20.000 - 30.000 km",
        "Više od 30.000 km"
      ]
    },
    {
      "id": "notes",
      "label": "Dodatne napomene",
      "type": "textarea",
      "rows": 4,
      "required": false
    }
